# ──────────────────────────────────────────────────────────
#  VideoManager – Environment Configuration
#  Copy this file to .env and fill in your credentials.
# ──────────────────────────────────────────────────────────

# FastAPI
APP_TITLE="VideoManager API"
API_PREFIX="/api"
# Comma-separated CORS origins. Use * for open access (not recommended in prod).
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Storage paths (relative to working directory)
DATA_DIR=data

# Chunking — smaller = faster playback start + snappier seeks (4–8 MB recommended)
CHUNK_SIZE_BYTES=8457280    # ~8 MB

# ── Gofile ────────────────────────────────────────────────
# Get your token from https://gofile.io/myProfile
GOFILE_TOKEN=OEa8ieC1gOFl1ZRdF43CXhS5QmEaNMIS
# Your account ID (shown on the profile page)
GOFILE_ACCOUNT_ID=b2035a6c-0c34-4a6e-a4a3-ea46b32eae11
# Optional: upload into a specific sub-folder instead of root
GOFILE_FOLDER_ID=

# ── Filester ──────────────────────────────────────────────
FILESTER_API_KEY=EjmIVHjkPO2HD5MbGLfEhjwtYkFYdVPW
FILESTER_BASE_URL=https://u1.filester.me
# Optional folder ID
FILESTER_FOLDER_ID=

# ── Cyberfile ─────────────────────────────────────────────
CYBERFILE_USERNAME=rolisa7430
CYBERFILE_PASSWORD=rolisa7430@hotkev.com
CYBERFILE_BASE_URL=https://cyberfile.me/api/v2
CYBERFILE_FOLDER_ID=

# ── Pixeldrain ────────────────────────────────────────────
PIXELDRAIN_API_KEY=8a7c0889-c6fc-4d5c-9941-74ca9e0e4e5b
# Priority (lower = tried first during streaming; higher = deprioritised)
# Free-tier Pixeldrain rate-limits range requests → set higher number
PIXELDRAIN_PRIORITY=3

# ── Google Drive (service account) ───────────────────────
# Path to the service account JSON key file
GDRIVE_SERVICE_ACCOUNT_JSON=config/gdrive-service-account.json
# Drive folder ID to upload thumbnails into (optional)
GDRIVE_FOLDER_ID=

# ── Streaming host priority (comma-separated, first = highest priority) ──
# Controls failover order during playback, and the order replica copies are placed.
# FileDitch first: free, no-auth and permanent — the best anchor copy.
STREAM_HOST_PRIORITY=["fileditch","filester","pixeldrain","cyberfile"]

# ── Streamtape ────────────────────────────────────────────────
# Enabled: also uploads whole-video parts (player ST mode). Uploads take longer.
STREAMTAPE_ENABLED=true
STREAMTAPE_LOGIN=4794180f060ae98b5f19
STREAMTAPE_KEY=ko33vJga46CY6r
# Optional: upload into a specific Streamtape folder
STREAMTAPE_FOLDER_ID=
# Max bytes per Streamtape part (hard limit is 15 GB; default 8 GB)
# Increase if your videos are large; decrease to split into more parts.
STREAMTAPE_PART_SIZE_BYTES=8589934592

# ── Buzzheavier ────────────────────────────────────────────────
# Your account ID from buzzheavier.com/account (used as Bearer token)
BUZZHEAVIER_ACCOUNT_ID=H3QG7IP1I2S61XQK1OHT
# Optional: directory ID to upload into
BUZZHEAVIER_FOLDER_ID=

# ── Stub adapters (no server API available yet) ───────────
# Set to true only if you have implemented the adapters
TURBOCR_ENABLED=false
JPGSU_ENABLED=false
