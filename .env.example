# ──────────────────────────────────────────────────────────
#  VideoManager – Environment Configuration
#  Copy this file to .env and fill in your credentials.
# ──────────────────────────────────────────────────────────

# FastAPI
APP_TITLE="VideoManager API"
API_PREFIX="/api"
# Comma-separated CORS origins. Use * for open access (not recommended in prod).
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Storage paths (relative to working directory)
DATA_DIR=data

# Chunking — target fMP4 chunk size (chunker snaps to keyframe boundaries).
# Smaller = faster playback start + snappier seeks. 4–8 MB is a good range.
CHUNK_SIZE_BYTES=6291456   # 6 MB

# ── Gofile ────────────────────────────────────────────────
# Get your token from https://gofile.io/myProfile
GOFILE_TOKEN=
# Your account ID (shown on the profile page)
GOFILE_ACCOUNT_ID=
# Optional: upload into a specific sub-folder instead of root
GOFILE_FOLDER_ID=

# ── Filester ──────────────────────────────────────────────
FILESTER_API_KEY=EjmIVHjkPO2HD5MbGLfEhjwtYkFYdVPW
FILESTER_BASE_URL=https://u1.filester.me
# Optional folder ID
FILESTER_FOLDER_ID=

# ── Cyberfile ─────────────────────────────────────────────
CYBERFILE_USERNAME=rolisa7430
CYBERFILE_PASSWORD=rolisa7430@hotkev.com
CYBERFILE_BASE_URL=https://cyberfile.me/api/v2
CYBERFILE_FOLDER_ID=

# ── Pixeldrain ────────────────────────────────────────────
PIXELDRAIN_API_KEY=8a7c0889-c6fc-4d5c-9941-74ca9e0e4e5b
# Priority (lower = tried first during streaming; higher = deprioritised)
# Free-tier Pixeldrain rate-limits range requests → set higher number
PIXELDRAIN_PRIORITY=3

# ── Google Drive (service account) ───────────────────────
# Path to the service account JSON key file
GDRIVE_SERVICE_ACCOUNT_JSON=config/gdrive-service-account.json
# Drive folder ID to upload thumbnails into (optional)
GDRIVE_FOLDER_ID=

# ── FileDitch (free, no-auth, permanent) ─────────────────
# No credentials required. Permanent retention (new.fileditch.com).
# Set to false to exclude it from the upload pool.
FILEDITCH_ENABLED=true

# ── Streaming host priority (comma-separated, first = highest priority) ──
# Controls failover order during playback, and the order replica copies are placed.
# FileDitch first: free, no-auth and permanent makes it the best anchor copy.
STREAM_HOST_PRIORITY=["fileditch","gofile","filester","cyberfile","pixeldrain"]

# ── Upload strategy ───────────────────────────────────────
# Number of host copies kept per chunk (durability vs upload speed).
# The expiry refresher maintains this count over time.
REPLICA_COUNT=2
# How many chunks to upload concurrently (pipelining across chunks).
UPLOAD_CONCURRENCY=3
# Max size of each browser→backend upload part. Keep < ~100 MB so dashboard
# uploads succeed through the Cloudflare tunnel (the file is sliced + reassembled).
UPLOAD_PART_SIZE_BYTES=50331648   # 48 MB

# ── Streamtape (whole-video parts; enables the player's ST mode) ──────────
# Re-uploads the entire video as <=8GB parts on top of the fMP4 chunks, so
# uploads take longer. Set to false to skip. Requires STREAMTAPE_LOGIN/KEY.
STREAMTAPE_ENABLED=true
STREAMTAPE_LOGIN=
STREAMTAPE_KEY=
STREAMTAPE_FOLDER_ID=

# ── Buzzheavier (optional) ────────────────────────────────
BUZZHEAVIER_ACCOUNT_ID=
BUZZHEAVIER_FOLDER_ID=

# ── Expiry refresher  (python -m backend.app.refresher) ───
# Seconds between passes in loop mode (default 6h).
REFRESH_INTERVAL_SEC=21600
# Re-upload a copy this many days before its estimated host expiry.
REFRESH_MARGIN_DAYS=7
# Also run the refresher in-process on a schedule (alongside the standalone CLI).
REFRESH_IN_APP=true
# Delay before the first in-app pass (seconds).
REFRESH_INITIAL_DELAY_SEC=120

# ── Cloudflare Tunnel (public HTTPS URL via cloudflared) ──
# Starts right after the backend boots. Requires the `cloudflared` binary in PATH.
# ⚠ The app has NO authentication — a tunnel exposes the dashboard (uploads/deletes)
#   publicly. Set to false to keep the app local-only.
CLOUDFLARE_TUNNEL_ENABLED=true
# Local address cloudflared forwards to (match your uvicorn host:port).
CLOUDFLARE_TUNNEL_TARGET=http://127.0.0.1:8000
# Optional: named-tunnel token (Cloudflare Zero Trust). If set, a stable named
# tunnel runs instead of an ephemeral *.trycloudflare.com quick tunnel.
CLOUDFLARE_TUNNEL_TOKEN=
# Optional: path/name of the cloudflared binary.
CLOUDFLARED_BIN=cloudflared

# ── Stub adapters (no server API available yet) ───────────
# Set to true only if you have implemented the adapters
TURBOCR_ENABLED=false
JPGSU_ENABLED=false
